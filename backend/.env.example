# Backend configuration (copy to .env and fill in as needed).

# Optional: override examples directory location.
# EXAMPLES_DIR=/app/examples

# Optional: LLM provider keys for the open-ended natural-language command parser.
# Leave all blank to use the deterministic rule-based parser (no key required).
# Set ONE of the following:
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional overrides:
# LLM_PROVIDER=gemini        # anthropic | openai | gemini (auto-detected if unset)
# LLM_MODEL=gemini-3-flash-preview
